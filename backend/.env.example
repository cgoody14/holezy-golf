# =============================================================================
# Holezy Booking Worker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# Never commit .env to git.
#
# On Railway: set these under your service's Variables tab.
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Resend (email notifications) ──────────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
# The "from" address (bookings@holezy.com) must be verified in your Resend account.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Booking platform credentials ──────────────────────────────────────────────
# Holezy company accounts on each supported booking platform.
# The worker logs in as Holezy and books using the saved company card.

# ChronoGolf (~13,730 courses)
CHRONOGOLF_EMAIL=your-chronogolf-email@example.com
CHRONOGOLF_PASSWORD=your-chronogolf-password

# GolfNow (thousands of US courses)
GOLFNOW_EMAIL=your-golfnow-email@example.com
GOLFNOW_PASSWORD=your-golfnow-password

# TeeOff (EZLinks platform)
TEEOFF_EMAIL=your-teeoff-email@example.com
TEEOFF_PASSWORD=your-teeoff-password

# Fore! Reservations (municipal / daily-fee courses)
FORE_EMAIL=your-fore-email@example.com
FORE_PASSWORD=your-fore-password

# Supreme Golf (aggregator — GolfNow + TeeOff + others)
SUPREME_EMAIL=your-supreme-email@example.com
SUPREME_PASSWORD=your-supreme-password

# ── Sentry (optional — error tracking) ────────────────────────────────────────
# Leave blank to disable Sentry. Get a DSN at: https://sentry.io
SENTRY_DSN=

# =============================================================================
# scheduled_jobs table schema (run this SQL in Supabase → SQL Editor)
# =============================================================================
#
# CREATE TABLE public.scheduled_jobs (
#   id                      UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
#   status                  TEXT        NOT NULL DEFAULT 'pending'
#                                         CHECK (status IN ('pending','running','booked','failed')),
#   fire_at                 TIMESTAMPTZ NOT NULL,
#
#   -- Golfer contact (for notifications)
#   golfer_email            TEXT        NOT NULL,
#   golfer_name             TEXT,
#
#   -- ChronoGolf login credentials for the golfer's account
#   -- Store encrypted at rest using Supabase Vault or pgcrypto
#   chronogolf_email        TEXT        NOT NULL,
#   chronogolf_password     TEXT        NOT NULL,
#
#   -- Booking parameters
#   course_name             TEXT        NOT NULL,
#   course_url              TEXT        NOT NULL,  -- e.g. https://www.chronogolf.com/club/1482
#   booking_date            DATE        NOT NULL,  -- e.g. 2026-05-15
#   earliest_time           TIME        NOT NULL,  -- e.g. 07:00
#   latest_time             TIME        NOT NULL,  -- e.g. 12:00
#   player_count            INT         NOT NULL DEFAULT 2,
#   max_price_per_player    NUMERIC(6,2),           -- NULL = no price limit
#
#   -- Results (populated by worker)
#   confirmation_code       TEXT,
#   attempts                INT         NOT NULL DEFAULT 0,
#   last_error              TEXT,
#
#   created_at              TIMESTAMPTZ NOT NULL DEFAULT now(),
#   updated_at              TIMESTAMPTZ NOT NULL DEFAULT now()
# );
#
# -- Index for fast pending-job lookups
# CREATE INDEX idx_scheduled_jobs_pending
#   ON public.scheduled_jobs (status, fire_at)
#   WHERE status = 'pending';
#
# -- RLS: service-role key bypasses all policies (worker uses service key)
# ALTER TABLE public.scheduled_jobs ENABLE ROW LEVEL SECURITY;
# =============================================================================
