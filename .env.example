SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# ============================================================
# Frontend (Vite) — must be prefixed VITE_ to reach the browser
# ============================================================

# Stripe publishable key (pk_test_... or pk_live_...)
# Required for the payment card element on the checkout page.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================================
# Booking Worker (booking-worker/.env)
# ============================================================

# Supabase service key (worker only — never expose to browser)
SUPABASE_SERVICE_KEY=

# Encryption key for stored platform passwords
# Generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# ChronoGolf / Lightspeed Partner API (apply: developer.lightspeedhq.com)
CHRONOGOLF_CLIENT_ID=
CHRONOGOLF_CLIENT_SECRET=

# GolfNow (apply: golfnow.com/business-partnership)
GOLFNOW_USERNAME=
GOLFNOW_PASSWORD=
GOLFNOW_CHANNEL_ID=

# foreUP (docs: foreup.docs.apiary.io)
FOREUP_API_KEY=
FOREUP_API_SECRET=

# Twilio — SMS notifications to golfers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Resend — transactional email
RESEND_API_KEY=
